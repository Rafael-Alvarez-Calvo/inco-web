# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Site key: public, safe to expose in the browser (VITE_ prefix required)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Secret key: NEVER expose this in the browser — only used in the serverless function
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ── SMTP Ionos ───────────────────────────────────────────────────────────────
# Used exclusively in netlify/functions/send-contact.ts (server-side only)
# Host: smtp.ionos.es  Port: 587  Security: STARTTLS
SMTP_USER=web@inco.com.es
SMTP_PASSWORD=your_smtp_password_here

# ── Google Maps ───────────────────────────────────────────────────────────────
# VITE_ prefix → bundled into frontend (Maps JS API keys are designed to be public,
# restrict to HTTP referrers in Google Cloud Console: inco.com.es/*)
# Enable in: https://console.cloud.google.com → APIs & Services → Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
